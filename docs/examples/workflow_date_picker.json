        "{date_short}",
        "liaozhu913-{date_short}-{time_short}",
        "liaozhu913-xwlb-{date_short}",
        "liaozhu913-ksfx-{date_short}-{time_short}",
        "{date_cn}",
        "{date_cn} {time_short}",
        "早报-{date_cn}-{time_short}",
        "{date_cn} 精选早安祝福语，星期问候动态图"
      ]
    }
  ]
